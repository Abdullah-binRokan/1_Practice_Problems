{
    "version": "2.0.0",
    "tasks": [
        {
                "label": "build active file",
            "type": "shell",
            "command": "clang",
            "args": [
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-lcs50"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}